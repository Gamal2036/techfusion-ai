generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Owner
  Admin
  Technician
  Viewer
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  devices Device[]
  deviceMetrics DeviceMetric[]
  deviceHealthScores DeviceHealthScore[]
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  isMfaEnabled    Boolean  @default(false)
  mfaSecret       String?
  mfaBackupCodes  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  role          Role   @default(Viewer)
  refreshTokens RefreshToken[]

  @@unique([orgId, email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
}

model Device {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  hostname    String?
  os          String?
  osVersion   String?
  cpuModel    String?
  cpuCores    Int?
  cpuLogical  Int?
  ramTotal    BigInt?
  gpuInfo     String?
  diskTotal   BigInt?
  isLaptop    Boolean  @default(false)
  registeredAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  deviceToken String   @unique
  metadata    Json?

  org     Organization        @relation(fields: [orgId], references: [id])
  metrics DeviceMetric[]
  scores  DeviceHealthScore[]

  @@index([orgId])
}

model DeviceMetric {
  id          String   @id @default(uuid())
  deviceId    String
  orgId       String
  recordedAt  DateTime @default(now())

  cpuUsage    Float   // percentage 0-100
  ramUsed     BigInt
  ramTotal    BigInt
  ramPercent  Float
  diskUsed    BigInt?
  diskTotal   BigInt?
  diskReadBytes  BigInt?
  diskWriteBytes BigInt?
  diskSmartStatus          String?  // "PASS" or "FAIL"
  diskSmartReallocatedSectors Int?
  diskSmartTemperature     Float?
  gpuUsage    Float?
  gpuTemp     Float?
  gpuMemoryUsed BigInt?
  batteryPercent Int?
  batteryStatus String?
  tempCpu     Float?
  tempGpu     Float?
  tempMotherboard Float?
  fanRpm      Int?
  networkRxBytes  BigInt?
  networkTxBytes  BigInt?
  loadAverage1Min Float?
  loadAverage5Min Float?
  loadAverage15Min Float?
  processes   Int?
  uptime      BigInt?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id])

  @@index([deviceId, recordedAt])
  @@index([orgId, recordedAt])
}

model DeviceHealthScore {
  id          String   @id @default(uuid())
  deviceId    String
  orgId       String
  calculatedAt DateTime @default(now())
  healthScore    Float  // 0-100, higher = healthier
  performanceScore Float // 0-100, higher = better
  riskScore      Float  // 0-100, higher = riskier

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id])

  @@index([deviceId, calculatedAt])
}
