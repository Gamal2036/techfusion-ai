generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Owner
  Admin
  Technician
  Viewer
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  devices Device[]
  deviceMetrics DeviceMetric[]
  deviceHealthScores DeviceHealthScore[]
  alertRules AlertRule[]
  alerts    Alert[]
  aiProviderConfigs AiProviderConfig[]
  aiUsageLogs AiUsageLog[]
  aiConversations AiConversation[]
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  isMfaEnabled    Boolean  @default(false)
  mfaSecret       String?
  mfaBackupCodes  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  role          Role   @default(Viewer)
  refreshTokens RefreshToken[]

  @@unique([orgId, email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
}

model Device {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  hostname    String?
  os          String?
  osVersion   String?
  cpuModel    String?
  cpuCores    Int?
  cpuLogical  Int?
  ramTotal    BigInt?
  gpuInfo     String?
  diskTotal   BigInt?
  isLaptop    Boolean  @default(false)
  registeredAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  deviceToken String   @unique
  metadata    Json?

  org     Organization        @relation(fields: [orgId], references: [id])
  metrics DeviceMetric[]
  scores  DeviceHealthScore[]
  alerts  Alert[]
  conversations AiConversation[]

  @@index([orgId])
}

model DeviceMetric {
  id          String   @id @default(uuid())
  deviceId    String
  orgId       String
  recordedAt  DateTime @default(now())

  cpuUsage    Float   // percentage 0-100
  ramUsed     BigInt
  ramTotal    BigInt
  ramPercent  Float
  diskUsed    BigInt?
  diskTotal   BigInt?
  diskReadBytes  BigInt?
  diskWriteBytes BigInt?
  diskSmartStatus          String?  // "PASS" or "FAIL"
  diskSmartReallocatedSectors Int?
  diskSmartTemperature     Float?
  gpuUsage    Float?
  gpuTemp     Float?
  gpuMemoryUsed BigInt?
  batteryPercent Int?
  batteryStatus String?
  tempCpu     Float?
  tempGpu     Float?
  tempMotherboard Float?
  fanRpm      Int?
  networkRxBytes  BigInt?
  networkTxBytes  BigInt?
  loadAverage1Min Float?
  loadAverage5Min Float?
  loadAverage15Min Float?
  processes   Int?
  uptime      BigInt?
  serviceChecks Json?

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id])

  @@index([deviceId, recordedAt])
  @@index([orgId, recordedAt])
}

model AlertRule {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  description String?
  metricName String
  threshold  Float
  operator   String   @default("gt")
  severity   String   @default("warning")
  debounceSeconds Int @default(300)
  enabled    Boolean  @default(true)
  deviceSelector String?
  webhookUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id])
  alerts Alert[]

  @@index([orgId])
}

model Alert {
  id          String    @id @default(uuid())
  orgId       String
  alertRuleId String
  deviceId    String
  metricValue Float
  threshold   Float
  severity    String
  message     String
  acknowledgedAt DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  alertRule AlertRule    @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  device    Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([alertRuleId])
  @@index([deviceId])
}

model DeviceHealthScore {
  id          String   @id @default(uuid())
  deviceId    String
  orgId       String
  calculatedAt DateTime @default(now())
  healthScore    Float  // 0-100, higher = healthier
  performanceScore Float // 0-100, higher = better
  riskScore      Float  // 0-100, higher = riskier

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id])

  @@index([deviceId, calculatedAt])
}

model AiProviderConfig {
  id             String   @id @default(uuid())
  orgId          String
  provider       String   // "anthropic", "openai"
  apiKeyEncrypted String
  baseUrl        String?  // optional custom base URL
  model          String   @default("claude-sonnet-4-20250514")
  priority       Int      @default(1)
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, provider])
  @@index([orgId, priority])
}

model AiUsageLog {
  id              String   @id @default(uuid())
  orgId           String
  conversationId  String?
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  costUsd         Float    @default(0)
  latencyMs       Int      @default(0)
  success         Boolean  @default(true)
  errorMessage    String?
  createdAt       DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

model AiConversation {
  id        String   @id @default(uuid())
  orgId     String
  title     String?
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id])
  device   Device?      @relation(fields: [deviceId], references: [id])
  messages AiMessage[]

  @@index([orgId, updatedAt])
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant" | "system"
  content        String
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
