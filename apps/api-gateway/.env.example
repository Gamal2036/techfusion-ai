# ═══════════════════════════════════════════════════════════════
# TechFusion AI — API Gateway Environment Configuration
# ═══════════════════════════════════════════════════════════════
# COPY this file to .env and fill in your values.
# ALL secrets below MUST be changed in production.
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL=""

# Authentication (MUST change these!)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Server
PORT=3001

# Encryption (MUST change this!)
AI_ENCRYPTION_KEY=""

# AI Provider API Keys (fill in the ones you use)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
AI_ROUTER_STRATEGY="smart"
AI_FALLBACK_ENABLED="true"
AI_ROUTER_TIMEOUT_MS="30000"
AI_CIRCUIT_BREAKER_THRESHOLD="3"
AI_CIRCUIT_BREAKER_RESET_MS="600000"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# CORS
ALLOWED_ORIGINS="http://localhost:3000"
